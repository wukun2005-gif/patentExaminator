# Token Plan API Key (deprecated, 使用 GEMINI_KEY 代替)
# TOKEN_PLAN_API_KEY=tp-your-key-here

# Optional overrides (defaults shown)
# TOKEN_PLAN_OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# TOKEN_PLAN_ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# TOKEN_PLAN_RATE_LIMIT_DELAY_MS=8000
# TOKEN_PLAN_MODEL_FALLBACKS=MiMo-V2.5-Pro,MiMo-V2.5,MiMo-V2-Pro,MiMo-V2-Omni

# Google AI Studio (Gemini) API Key (开发测试和APP默认使用)
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_KEY=your-gemini-key-here

# Gemini 模型选择（可选，默认 gemini-2.5-flash-lite）
# GEMINI_MODEL_ID=gemini-2.5-flash-lite

# Tavily Search API Key (optional, for web search features)
# TAVILY_API_KEY=your-tavily-key-here

# Qwen (DashScope) API Key (阿里通义千问)
# Get your key at: https://dashscope.console.aliyun.com/apiKey
# QWEN_KEY=your-qwen-key-here
